{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TreeScout",
  "version": "0.1.0",
  "identifier": "com.nao.treescout",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TreeScout",
        "width": 900,
        "height": 640,
        "minWidth": 360,
        "minHeight": 240,
        "devtools": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["Everything64.dll"]
  }
}
